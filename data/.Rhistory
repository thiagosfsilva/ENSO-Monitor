# We determine what the intercept and slope of our 'true' model are and
# add it to the equation, then we draw 40 numbers from a normal distribution
#  with mean = 0 and s.d. = 5 and add them to the linear equation.
y <- 2.5 + 0.5 * x + rnorm(40,0,5)
# What did we get?
print(y)
# Does it look normally distributed?
hist(y,breaks=10)
# First we collate x and y into a dataframe for tidiness
model_data <- data.frame(x = x, y = y)
# Does it look correct? Let us look at the top values.
head(model_data)
# Then we fit the model and check the results
m <- lm(y ~ x, data = model_data)
summary(m)
# Plotting the points then fitting a linear model using geom_smooth
ggplot(model_data,aes(x,y)) + geom_point() + geom_smooth(method='lm')
# We can also repeat the plot and add the 'true' regression line as defined by our simulation:
# Plotting the points then fitting a linear model using geom_smooth
ggplot(model_data,aes(x,y)) + geom_point() +
geom_smooth(method='lm') +
geom_abline(intercept = 2.5, slope = 0.5, colour='red')
