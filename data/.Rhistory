# How does our data frame look now?
head(model_data)
# We will also simulate an 'effect' of belonging to group B by adding a random number
# to all observations of group B. This randoim number follows a normal distribution
# with mean = 5 and sd = 2.
set.seed(45)
b_effects <- rnorm(25,5,2)
# And then we concatenate the two sets of values and add them to the Y values
categorical_effects <- c(a_effects,b_effects)
# We create 25 observations of 'no effect' to add to the A group
a _effects <- rep(0,25)
# We create 25 observations of 'no effect' to add to the A group
a_effects <- rep(0,25)
# And then we concatenate the two sets of values and add them to the Y values
categorical_effects <- c(a_effects,b_effects)
model_data$y <- model_data$y + categorical_effects
# We will also simulate an 'effect' of belonging to group B by adding a random number
# to all observations of group B. This random number follows a normal distribution
# with mean = 5 and sd = 2.
set.seed(45)
b_effects <- rnorm(20,5,2)
# We create 20 observations of 'no effect' to add to the A group
a_effects <- rep(0,20)
# And then we concatenate the two sets of values and add them to the Y values
categorical_effects <- c(a_effects,b_effects)
model_data$y <- model_data$y + categorical_effects
# How does our data frame look now?
head(model_data)
# Simulating a categorical variable z with two groups (A and B) and add it to the data frame.
# We use the rep function to repeat the letters A and B 20 times each
# and then transform them from strings to a factor with as.factor().
model_data$z <- as.factor(c(rep('A',20),rep('B',20)))
# How does our data frame look now?
head(model_data)
m2 <- lm(y ~ z, data = model_data)
summary(m2)
b_effects <- rnorm(20,10,2)
# We will also simulate an 'effect' of belonging to group B by adding a random number
# to all observations of group B. This random number follows a normal distribution
# with mean = 5 and sd = 2.
# That means that on average we expect y values from group B to be 5 units larger than for group A.
set.seed(45)
b_effects <- rnorm(20,10,2)
# We create 20 observations of 'no effect' to add to the A group
a_effects <- rep(0,20)
# And then we concatenate the two sets of values and add them to the Y values
categorical_effects <- c(a_effects,b_effects)
model_data$y <- model_data$y + categorical_effects
# How does our data frame look now?
head(model_data)
m2 <- lm(y ~ z, data = model_data)
summary(m2)
summary(m2)$
p.val
t <- summary(m2)
t
t$fstatistic
t <- summary(m2)$coefficients[,4]
t
summary(m2)$coefficients[2,4]
# We can pull just the coefficients from the model:
m2$coefficients
# So (Intercept) is the expected average for Y when Z='A'
# And zB is how much larger/smaller the expected average is for Y when Z='B'
# in relation to the expectation for 'A'.
#
# We can then calculate the expected averages of Y for each level.
# When Z=A, it is just:
Y_a <- m2$coefficients[1]
# When Z=B, then we add the two coefficients:
Y_b <- m2$coefficients[1] + m2$coefficients[2]
# Are our calculated intercepts really the expected averages? Let us compare
# to the actual averages of each group:
print(Y_a)
print(Y_b)
# Calculating the means directly from the data using dplyr
library(dplyr)
means <- model_data %>% group_by(z) %>% summarise(group_mean = mean(y))
print(means)
m3 <- lm(y ~ x + z, data = model_data)
summary(m3)
# Intercept for when Z=A
Y_a <- m3$coefficients[1]
Y_a
#Intercept when Z=B
Y_b <- m3$coefficients[1] + m3$coefficients[3]
Y_b
ggplot(model_data,aes(X,Y)) + geom_point(aes(colour = Z)) + geom_smooth(aes(colour = Z),method='lm')
model_data
ggplot(model_data,aes(x,y)) + geom_point(aes(colour = z)) + geom_smooth(aes(colour = z),method='lm')
